"""Tests for artwork page — structure and nav contracts."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)

from __future__ import annotations


class TestArtworkNav:
    def test_artwork_route_in_nav_routes(self):
        from legacy_widgets.ui.controllers.legacy_controllers.navigation_controller import NAV_ROUTES
        assert "audio_lab_artwork" in NAV_ROUTES

    def test_artwork_section_config(self):
        from legacy_widgets.ui.controllers.legacy_controllers.navigation_controller import SECTION_CONFIG
        assert "audio_lab_artwork" in SECTION_CONFIG
        cfg = SECTION_CONFIG["audio_lab_artwork"]
        assert "title" in cfg and "subtitle" in cfg and "icon" in cfg

    def test_artwork_sidebar_key(self):
        from legacy_widgets.ui.controllers.legacy_controllers.navigation_controller import resolve_sidebar_active_key
        assert resolve_sidebar_active_key("audio_lab_artwork") == "audio_lab"
