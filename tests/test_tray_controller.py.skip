"""Tests for TrayController — setup, menu, icon property."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
from unittest.mock import MagicMock, patch

import pytest


@pytest.fixture
def mock_qapp():
    """Ensure QApplication exists for Qt widget tests."""
    from PySide6.QtWidgets import QApplication
    app = QApplication.instance()
    if app is None:
        app = QApplication([])
    yield app


class TestTrayController:
    @pytest.fixture
    def ctrl(self):
        from legacy_widgets.ui.controllers.legacy_controllers.tray_controller import TrayController
        window = MagicMock()
        window._ctx = MagicMock()
        window._ctx.playback = MagicMock()
        return TrayController(window)

    def test_setup_creates_icon(self, mock_qapp, ctrl):
        with (patch("ui.controllers.tray_controller.QSystemTrayIcon", autospec=True) as mock_tray_cls,
              patch("ui.controllers.tray_controller.get_tray_icon", return_value=MagicMock())):
            mock_icon = mock_tray_cls.return_value
            ctrl.setup()
            mock_tray_cls.assert_called_once()
            assert ctrl._icon is mock_icon

    def test_setup_calls_show(self, mock_qapp, ctrl):
        with (patch("ui.controllers.tray_controller.QSystemTrayIcon", autospec=True) as mock_tray_cls,
              patch("ui.controllers.tray_controller.get_tray_icon", return_value=MagicMock())):
            mock_icon = mock_tray_cls.return_value
            ctrl.setup()
            mock_icon.show.assert_called_once()

    def test_setup_sets_context_menu(self, mock_qapp, ctrl):
        with (patch("ui.controllers.tray_controller.QSystemTrayIcon", autospec=True) as mock_tray_cls,
              patch("ui.controllers.tray_controller.get_tray_icon", return_value=MagicMock()),
              patch("ui.controllers.tray_controller.QMenu", autospec=True)):
            mock_icon = mock_tray_cls.return_value
            ctrl.setup()
            mock_icon.setContextMenu.assert_called_once()

    def test_icon_property_returns_icon(self, mock_qapp, ctrl):
        with (patch("ui.controllers.tray_controller.QSystemTrayIcon", autospec=True),
              patch("ui.controllers.tray_controller.get_tray_icon", return_value=MagicMock()),
              patch("ui.controllers.tray_controller.QMenu", autospec=True)):
            ctrl.setup()
            assert ctrl.icon is ctrl._icon

    def test_no_unreachable_code_after_return(self, ctrl):
        """Verify the icon property has no unreachable code after its return."""
        import inspect
        source_file = inspect.getfile(type(ctrl))
        with open(source_file) as f:
            content = f.read()
        prop_idx = content.find("def icon(self):")
        assert prop_idx > -1, "icon property not found in source"
        prop_section = content[prop_idx:].split("\n\n")[0]
        lines = prop_section.split("\n")
        return_idx = next(i for i, line in enumerate(lines)
                         if "return" in line and "self._icon" in line)
        after_return = [ln.strip() for ln in lines[return_idx + 1:]
                       if ln.strip() and not ln.strip().startswith("#")]
        assert after_return == [], f"Code after return in icon property: {after_return}"
