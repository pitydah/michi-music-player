"""Tests for Linux platform support (HV)."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
import os
import platform
import subprocess
from pathlib import Path

import pytest

REPO = Path(__file__).resolve().parent


class TestLinuxPlatformDetection:
    def test_platform_is_linux(self):
        assert platform.system() in ("Linux",), "Tests require Linux"

    def test_xdg_paths_available(self):
        from core.paths import database_path, app_config_dir, app_cache_dir, app_data_dir
        for p in (database_path, app_config_dir, app_cache_dir, app_data_dir):
            path = p()
            assert isinstance(path, str)
            assert path.startswith("/")

    def test_xdg_data_home(self):
        data = os.environ.get("XDG_DATA_HOME", os.path.expanduser("~/.local/share"))
        assert data is not None

    def test_xdg_config_home(self):
        config = os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
        assert config is not None

    def test_xdg_cache_home(self):
        cache = os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache"))
        assert cache is not None


class TestLinuxDisplay:
    def test_wayland_env_var(self):
        # Wayland is preferred; either is OK
        valid = {"wayland", "x11", "offscreen"}
        platform_var = os.environ.get("QT_QPA_PLATFORM", "").lower()
        if platform_var:
            assert platform_var in valid, f"Unexpected platform: {platform_var}"

    def test_x11_display_available(self):
        # When under X11, DISPLAY should be set
        display = os.environ.get("DISPLAY")
        wayland = os.environ.get("WAYLAND_DISPLAY")
        offscreen = os.environ.get("QT_QPA_PLATFORM") == "offscreen"
        if not offscreen:
            assert display or wayland, "No display available"

    def test_dbus_session_bus(self):
        addr = os.environ.get("DBUS_SESSION_BUS_ADDRESS")
        if addr:
            assert ":" in addr


class TestLinuxNotifications:
    def test_dbus_notifications_available(self):
        try:
            result = subprocess.run(
                ["dbus-send", "--session", "--dest=org.freedesktop.DBus",
                 "--type=method_call", "--print-reply",
                 "/org/freedesktop/DBus", "org.freedesktop.DBus.ListNames"],
                capture_output=True, text=True, timeout=5,
            )
            has_notifications = "org.freedesktop.Notifications" in result.stdout
        except (FileNotFoundError, subprocess.TimeoutExpired):
            has_notifications = False
        if has_notifications:
            assert has_notifications
        else:
            pytest.skip("DBus notifications not available")

    def test_notification_service_import(self):
        from core.notification_service import NotificationService
        assert NotificationService is not None


class TestLinuxFilesystem:
    def test_reserved_paths_no_issues(self):
        paths = ["/tmp", "/var/tmp", os.path.expanduser("~")]
        for p in paths:
            assert os.access(p, os.R_OK), f"Path not readable: {p}"

    def test_home_is_accessible(self):
        home = os.path.expanduser("~")
        assert os.path.isdir(home)

    def test_music_dirs_resolve(self):
        xdg_music = os.environ.get("XDG_MUSIC_DIR", os.path.join(os.path.expanduser("~"), "Music"))
        assert isinstance(xdg_music, str)

    def test_proc_filesystem_available(self):
        assert os.access("/proc/self/status", os.R_OK)


class TestLinuxMediaKeys:
    def test_mpris_import(self):
        try:
            from legacy_widgets.ui.controllers.legacy_controllers.mpris_controller import MprisController
            assert MprisController is not None
        except ImportError:
            from ui_qml_bridge.desktop_bridge import DesktopBridge
            assert DesktopBridge is not None

    def test_dbus_media_player_service(self):
        try:
            result = subprocess.run(
                ["dbus-send", "--session", "--dest=org.freedesktop.DBus",
                 "--type=method_call", "--print-reply",
                 "/org/freedesktop/DBus", "org.freedesktop.DBus.ListNames"],
                capture_output=True, text=True, timeout=5,
            )
            has_mpris = "org.mpris.MediaPlayer2" in result.stdout
        except (FileNotFoundError, subprocess.TimeoutExpired):
            has_mpris = False
        if has_mpris:
            assert has_mpris
        else:
            pytest.skip("MPRIS service not detected")

    def test_keyboard_shortcuts_module(self):
        from core.shutdown_manager import ShutdownManager
        assert ShutdownManager is not None


class TestLinuxFlatpak:
    def test_flatpak_spawn_available(self):
        flatpak = os.environ.get("FLATPAK_ID")
        if flatpak:
            assert isinstance(flatpak, str)

    def test_core_paths_xdg_compliant(self):
        from core.paths import database_path, app_config_dir, app_cache_dir, app_data_dir
        for p in (database_path, app_config_dir, app_cache_dir, app_data_dir):
            path = p()
            assert path.startswith("/")
            assert ".." not in path
