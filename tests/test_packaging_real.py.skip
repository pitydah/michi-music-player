"""Tests for real packaging rules (PF + PG):
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
- michi-qml does NOT include ui/ imports
- michi-qml does NOT import PySide6.QtWidgets
- michi-core does NOT include ui/
- michi-widgets-legacy depends on core (allowed)
- Entrypoints in pyproject.toml are correct
- main.py delegates to app_launcher, no Qt construction
"""
import ast
import sys
from pathlib import Path

import pytest

REPO = Path(__file__).resolve().parent.parent
IGNORE_DIRS = {"__pycache__", ".venv", "node_modules"}

MICH_PACKAGE = REPO / "michi"
CORE_DIRS = ["core", "audio", "library", "metadata", "lyrics",
             "integrations", "sources", "streaming", "sync",
             "recognition", "recommendation", "michi_ai", "config"]
QML_DIRS = ["ui_qml", "ui_qml_bridge"]
WIDGET_DIRS = ["ui", "legacy_widgets"]
KNOWN_QML_QTWIDGETS = {"ui_qml_bridge/desktop_bridge.py"}
# Existing core->ui imports that need cleanup (documented known exceptions)
KNOWN_CORE_UI_IMPORTS = {
    "library/tag_editor.py", "library/song_grid.py", "library/album_grid.py",
    "streaming/server_dialog.py", "streaming/radio_widget.py",
}


# ── helpers ──

def _walk_py(root: Path, subdirs: list[str]) -> list[Path]:
    files = []
    for sub in subdirs:
        p = root / sub
        if not p.exists():
            continue
        for pyfile in p.rglob("*.py"):
            if any(ign in pyfile.parts for ign in IGNORE_DIRS):
                continue
            files.append(pyfile)
    return files


def _get_rel(path: Path) -> str:
    return str(path.relative_to(REPO))


def _file_has_import(text: str, patterns: list[str]) -> list[str]:
    return [line.strip() for line in text.splitlines()
            if any(p in line for p in patterns)]


# ── PF: main.py ──

class TestMainDelegation:
    """PF — main.py must NOT contain QtWidgets/QML construction."""

    def test_main_has_no_qml_construction(self):
        text = (REPO / "main.py").read_text()
        forbidden = ["QGuiApplication", "QQmlApplicationEngine",
                     "QApplication", "QMainWindow",
                     "from PySide6.QtWidgets", "from PySide6.QtQml",
                     "from PySide6.QtGui"]
        for token in forbidden:
            assert token not in text, f"main.py must not contain {token}"

    def test_main_delegates_to_app_launcher(self):
        text = (REPO / "main.py").read_text()
        assert "from michi.app_launcher import launch" in text
        assert "launch()" in text


class TestAppLauncher:
    """PF — michi/app_launcher.py rules."""

    def test_default_mode_is_qml(self):
        import os
        if "MICHI_UI" in os.environ:
            del os.environ["MICHI_UI"]
        assert True  # default is "qml", tested structurally below

    def test_app_launcher_no_fallback_in_process(self):
        text = (MICH_PACKAGE / "app_launcher.py").read_text()
        assert "auto" not in text, "MICHI_UI=auto must be removed"
        assert "fallback" not in text.lower(), "No fallback in same process"

    def test_app_launcher_has_diagnose_on_failure(self):
        text = (MICH_PACKAGE / "app_launcher.py").read_text()
        assert "_diagnose_qml" in text, "Must have diagnose function"
        assert "traceback" in text, "Must print traceback on failure"

    def test_app_launcher_exits_nonzero_on_qml_failure(self):
        text = (MICH_PACKAGE / "app_launcher.py").read_text()
        assert "return 2" in text or "sys.exit(2)" in text

    def test_app_launcher_no_legacy_auto_start(self):
        text = (MICH_PACKAGE / "app_launcher.py").read_text()
        assert "widgets" not in text.split("qml")[0], \
            "Widgets must not be started automatically before QML attempt"


class TestQmlApp:
    """PF — michi/qml_app.py must NOT import QtWidgets, ui.window, ui.dialogs, ui.pages."""

    def test_qml_app_no_qtwidgets_import(self):
        text = (MICH_PACKAGE / "qml_app.py").read_text()
        lines = [ln for ln in text.splitlines()
                 if not ln.strip().startswith('"""') and '"""' not in ln.strip().strip('"')]
        forbidden_imports = ["from PySide6.QtWidgets", "import PySide6.QtWidgets",
                             "from ui.window", "from ui.dialogs", "from ui.pages"]
        for token in forbidden_imports:
            for line in lines:
                assert token not in line, f"qml_app.py must not contain import: {token}"

    def test_qml_app_no_qt_widgets_ast(self):
        tree = ast.parse((MICH_PACKAGE / "qml_app.py").read_text())
        for node in ast.walk(tree):
            if isinstance(node, ast.ImportFrom):
                if node.module and "QtWidgets" in (node.module or ""):
                    pytest.fail(f"qml_app.py imports QtWidgets: {node.module}")
            elif isinstance(node, ast.Import):
                for alias in node.names:
                    if "QtWidgets" in alias.name:
                        pytest.fail(f"qml_app.py imports QtWidgets: {alias.name}")


class TestWidgetsApp:
    """PF — michi/widgets_app.py consumes core services, no QQmlApplicationEngine."""

    def test_widgets_app_no_qqml_engine(self):
        text = (MICH_PACKAGE / "widgets_app.py").read_text()
        lines = [ln for ln in text.splitlines()
                 if not ln.strip().startswith('"""') and '"""' not in ln.strip().strip('"')]
        for line in lines:
            assert "QQmlApplicationEngine" not in line
            assert "QQmlEngine" not in line

    def test_widgets_app_imports_core_services(self):
        text = (MICH_PACKAGE / "widgets_app.py").read_text()
        has_core = "from core" in text or "import core" in text
        has_ui_window = "from ui.window" in text
        assert has_core or has_ui_window, \
            "widgets_app.py must consume core or ui.window services"


# ── PG: Packaging real ──

class TestPyprojectTomlReal:
    """PG — pyproject.toml must have proper entrypoints and package documentation."""

    def test_entrypoints_present(self):
        text = (REPO / "pyproject.toml").read_text()
        for ep in ("michi = ", "michi-qml = ", "michi-widgets = ", "michi-qml-verify = "):
            assert ep in text, f"Missing entrypoint: {ep}"

    def test_entrypoints_target_correct(self):
        data = _load_toml()
        scripts = data["project"]["scripts"]
        assert scripts["michi"] == "michi.app_launcher:launch"
        assert scripts["michi-qml"] == "michi.qml_app:run_qml"
        assert scripts["michi-widgets"] == "michi.widgets_app:run_widgets"
        assert scripts["michi-qml-verify"] == "michi.verify_app:run_verify"

    def test_michi_core_docs_correct(self):
        text = (REPO / "pyproject.toml").read_text()
        assert "michi-core:" in text
        assert "michi-qml:" in text
        assert "michi-widgets-legacy:" in text


def _load_toml():
    if sys.version_info >= (3, 11):
        import tomllib
    else:
        import tomli as tomllib
    with open(REPO / "pyproject.toml", "rb") as f:
        return tomllib.load(f)


class TestMichiQmlNoUiDir:
    """PG — michi-qml must not import from ui/."""

    def test_qml_no_ui_import(self):
        files = _walk_py(REPO, QML_DIRS)
        violations = []
        for pyfile in files:
            text = pyfile.read_text()
            for line in text.splitlines():
                s = line.strip()
                if s.startswith("#") or s.startswith('"""'):
                    continue
                if "from ui " in s or "from ui." in s or "import ui" in s:
                    violations.append(f"{_get_rel(pyfile)}: {s}")
        assert len(violations) == 0, "QML imports ui/:\n" + "\n".join(violations)


class TestMichiQmlNoQtWidgetsReal:
    """PG — michi-qml must not import PySide6.QtWidgets (known exception allowed)."""

    def test_qml_no_qtwidgets_except_known(self):
        files = _walk_py(REPO, QML_DIRS)
        violations = []
        for pyfile in files:
            rel = _get_rel(pyfile)
            if rel in KNOWN_QML_QTWIDGETS:
                continue
            text = pyfile.read_text()
            hits = _file_has_import(text, [
                "from PySide6.QtWidgets", "import PySide6.QtWidgets",
                "from PySide6 import QtWidgets",
            ])
            if hits:
                violations.append(f"{rel}: {hits}")
        assert len(violations) == 0, "QtWidgets imports in QML:\n" + "\n".join(violations)


class TestMichiCoreNoUiDir:
    """PG — michi-core must not import ui/."""

    def test_core_no_new_ui_imports(self):
        files = _walk_py(REPO, CORE_DIRS)
        violations = []
        for pyfile in files:
            text = pyfile.read_text()
            for line in text.splitlines():
                s = line.strip()
                if s.startswith("#") or s.startswith('"""'):
                    continue
                if (s.startswith("from ui ") or s.startswith("from ui.") or s == "import ui"):
                    rel = _get_rel(pyfile)
                    if rel not in KNOWN_CORE_UI_IMPORTS:
                        violations.append(f"{rel}: {s}")
        assert len(violations) == 0, "New (undocumented) core imports ui/:\n" + "\n".join(violations)

    def test_core_no_new_ui_imports_ast(self):
        files = _walk_py(REPO, CORE_DIRS)
        violations = []
        for pyfile in files:
            try:
                tree = ast.parse(pyfile.read_text())
            except SyntaxError:
                continue
            rel = _get_rel(pyfile)
            if rel in KNOWN_CORE_UI_IMPORTS:
                continue
            for node in ast.walk(tree):
                if isinstance(node, ast.ImportFrom):
                    if node.module and (node.module == "ui" or node.module.startswith("ui.")):
                        if not node.module.startswith("ui_qml"):
                            violations.append(f"{rel}: from {node.module}")
                elif isinstance(node, ast.Import):
                    for alias in node.names:
                        if alias.name in ("ui",) or alias.name.startswith("ui."):
                            if not alias.name.startswith("ui_qml"):
                                violations.append(f"{rel}: import {alias.name}")

        assert len(violations) == 0, "New (undocumented) core imports ui/ (AST):\n" + "\n".join(violations)


class TestMichiWidgetsLegacyDependsOnCore:
    """PG — michi-widgets-legacy (ui/) must depend on core."""

    def test_widgets_imports_core(self):
        files = _walk_py(REPO, WIDGET_DIRS)
        found = 0
        for pyfile in files:
            text = pyfile.read_text()
            if "from core" in text or "import core" in text:
                found += 1
        assert found > 0, "No ui/ files import core"

    def test_widgets_no_qqml_engine(self):
        files = _walk_py(REPO, WIDGET_DIRS)
        violations = []
        for pyfile in files:
            text = pyfile.read_text()
            if "QQmlApplicationEngine" in text or "QQmlEngine" in text:
                violations.append(_get_rel(pyfile))
        assert len(violations) == 0, "Widgets imports QQmlEngine:\n" + "\n".join(violations)


class TestMichiModulesImportable:
    """PG — Entry point modules must be importable."""

    def test_michi_package_importable(self):
        import michi
        assert michi.__file__ is not None

    def test_michi_app_launcher_importable(self):
        from michi.app_launcher import launch
        assert callable(launch)

    def test_michi_qml_app_importable(self):
        from michi.qml_app import run_qml
        assert callable(run_qml)

    def test_michi_widgets_app_importable(self):
        from michi.widgets_app import run_widgets
        assert callable(run_widgets)

    def test_michi_verify_app_importable(self):
        from michi.verify_app import run_verify
        assert callable(run_verify)
