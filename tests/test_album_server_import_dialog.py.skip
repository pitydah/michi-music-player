"""Tests for AlbumServerImportDialog — preflight, confirm, progress, report."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
from __future__ import annotations


class TestAlbumServerImportDialog:
    def test_dialog_creates(self, qtbot):
        from legacy_widgets.ui.dialogs.album_server_import_dialog import AlbumServerImportDialog
        from PySide6.QtWidgets import QWidget
        parent = QWidget()
        qtbot.addWidget(parent)
        dlg = AlbumServerImportDialog(parent, "Album", 10, 5, 5)
        assert dlg.windowTitle() == "Enviar álbum a Michi Micro Server"
        assert dlg.was_confirmed() is False

    def test_dialog_confirm(self, qtbot):
        from legacy_widgets.ui.dialogs.album_server_import_dialog import AlbumServerImportDialog
        from PySide6.QtWidgets import QWidget
        parent = QWidget()
        qtbot.addWidget(parent)
        dlg = AlbumServerImportDialog(parent, "A", 3, 1, 2)
        dlg._on_confirm()
        assert dlg.was_confirmed() is True

    def test_dialog_progress(self, qtbot):
        from legacy_widgets.ui.dialogs.album_server_import_dialog import AlbumServerImportDialog
        from PySide6.QtWidgets import QWidget
        parent = QWidget()
        qtbot.addWidget(parent)
        dlg = AlbumServerImportDialog(parent, "A", 10, 0, 10)
        dlg.set_progress(5, 10)
        assert dlg._progress.value() == 5
        assert dlg._progress.maximum() == 10

    def test_show_report_success(self, qtbot):
        from legacy_widgets.ui.dialogs.album_server_import_dialog import AlbumServerImportDialog
        from PySide6.QtWidgets import QWidget
        from unittest.mock import patch
        parent = QWidget()
        qtbot.addWidget(parent)
        with patch("PySide6.QtWidgets.QMessageBox.information") as mock_info:
            AlbumServerImportDialog.show_report(parent, "OK", "All good", is_error=False)
            mock_info.assert_called_once()

    def test_show_report_error(self, qtbot):
        from legacy_widgets.ui.dialogs.album_server_import_dialog import AlbumServerImportDialog
        from PySide6.QtWidgets import QWidget
        from unittest.mock import patch
        parent = QWidget()
        qtbot.addWidget(parent)
        with patch("PySide6.QtWidgets.QMessageBox.critical") as mock_critical:
            AlbumServerImportDialog.show_report(parent, "Error", "Failed", is_error=True)
            mock_critical.assert_called_once()
