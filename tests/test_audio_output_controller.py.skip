"""Tests for AudioOutputController."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
import builtins
from unittest.mock import MagicMock, patch

import pytest


@pytest.fixture
def win():
    w = MagicMock()
    w._ctx = MagicMock()
    w._ctx.playback = MagicMock()
    w._ctx.player_bar = MagicMock()
    return w


@pytest.fixture
def ctrl(win):
    from legacy_widgets.ui.controllers.legacy_controllers.audio_output_controller import AudioOutputController
    return AudioOutputController(win)


class TestAudioOutputController:
    def test_init_sets_win_ctx_svc(self, ctrl, win):
        assert ctrl._win is win
        assert ctrl._ctx is win._ctx
        assert ctrl._svc is None

    def test_show_menu_creates_menu_with_devices(self, ctrl, win):
        with (patch("ui.controllers.audio_output_controller.QMenu") as mock_menu_cls,
              patch("ui.premium_menus.premium_menu_qss") as mock_qss):
            mock_menu = mock_menu_cls.return_value
            mock_qss.return_value = "qss"
            win._ctx.playback.get_output_device_id.return_value = "auto"
            ctrl._list_devices = MagicMock(return_value=[("Device1", "dev1")])
            ctrl.show_menu()
            mock_menu_cls.assert_called_once_with(win)
            mock_menu.setStyleSheet.assert_called_with("qss")

    def test_show_menu_handles_no_devices(self, ctrl, win):
        with (patch("ui.controllers.audio_output_controller.QMenu") as mock_menu_cls,
              patch("ui.premium_menus.premium_menu_qss")):
            mock_menu = mock_menu_cls.return_value
            win._ctx.playback.get_output_device_id.return_value = None
            ctrl._list_devices = MagicMock(return_value=[])
            ctrl.show_menu()
            calls = [a[0][0] for a in mock_menu.addAction.call_args_list]
            assert any("No se detectaron" in str(c) for c in calls)

    def test_show_menu_creates_menu_with_preferences_action(self, ctrl, win):
        with (patch("ui.controllers.audio_output_controller.QMenu"),
              patch("ui.premium_menus.premium_menu_qss")):
            ctrl._list_devices = MagicMock(return_value=[])
            win._ctx.playback.get_output_device_id.return_value = "auto"
            ctrl.show_menu()
            actions = win._ctx.player_bar.audio_output_button.return_value
            actions.mapToGlobal.assert_called_once()

    def test_list_devices_returns_empty_on_exception(self):
        from legacy_widgets.ui.controllers.legacy_controllers.audio_output_controller import AudioOutputController
        original_import = builtins.__import__
        def fake_import(name, *args, **kwargs):
            if name == "gi":
                raise ImportError("no gi")
            return original_import(name, *args, **kwargs)
        with (patch.object(builtins, "__import__", side_effect=fake_import),
              patch("ui.controllers.audio_output_controller.logging")):
            result = AudioOutputController._list_devices()
        assert result == []
