"""Tests for VinylLabPage — requires pytest-qt."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)

from unittest.mock import patch


def test_vinyl_page_renders(qtbot):
    from legacy_widgets.ui.audio_lab.vinyl_lab_page import VinylLabPage
    page = VinylLabPage()
    qtbot.addWidget(page)
    page.show()
    assert page.isVisible()
    assert page.navigate_requested is not None


def test_vinyl_export_no_recording_no_crash(qtbot):
    from legacy_widgets.ui.audio_lab.vinyl_lab_page import VinylLabPage
    page = VinylLabPage()
    qtbot.addWidget(page)
    with patch("ui.audio_lab.vinyl_lab_page.QMessageBox.information"):
        page._export_and_import()


def test_vinyl_export_no_split_points_no_crash(qtbot):
    from legacy_widgets.ui.audio_lab.vinyl_lab_page import VinylLabPage
    import tempfile
    import os
    page = VinylLabPage()
    qtbot.addWidget(page)
    with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as f:
        path = f.name
    try:
        page._side_a_path = path
        page._split_points = []
        with patch("ui.audio_lab.vinyl_lab_page.QMessageBox.information"):
            page._export_and_import()
    finally:
        os.unlink(path)
