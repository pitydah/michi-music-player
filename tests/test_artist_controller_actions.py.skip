"""Tests for ArtistController actions like mix, analysis, micro server."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
from unittest.mock import MagicMock
from legacy_widgets.ui.controllers.legacy_controllers.artist_controller import ArtistController
from library.library_db import MediaItem


def _make_item(**kw):
    defaults = dict(
        id=0, filepath="/tmp/track.flac", filename="track.flac",
        directory="/tmp", ext="flac", kind="audio",
        size=0, mtime=0.0, duration=200.0,
        channels=2, sample_rate=44100, bitrate=1000,
        title="Test", artist="Test Artist", album="Test Album",
        year=2020, genre="Rock",
        track_number=1, composer="",
        albumartist="", disc_number=1, disc_total=1, track_total=10,
        mb_track_id="", mb_album_id="", mb_albumartist_id="",
        bit_depth=16, bpm=120, isrc="", label="",
        conductor="", compilation=0, media_type="",
        encoder="", copyright="", originaldate="",
        remixer="", grouping="", mood="",
        replaygain_track=0.0, replaygain_album=0.0,
        replaygain_track_peak=0.0,
        play_count=5, last_played=0.0, rating=0,
        created_at=0.0, updated_at=0.0, last_scanned=0.0,
        track_uid="",
    )
    defaults.update(kw)
    return MediaItem(**defaults)


class TestArtistControllerActions:
    def setup_method(self):
        self.mock_win = MagicMock()
        self.mock_win._artist_repo = __import__(
            "ui.controllers.artist_repository",
            fromlist=["ArtistRepository"],
        ).ArtistRepository()
        self.mock_win._ctx = MagicMock()
        self.mock_win._ctx.artist_repo = self.mock_win._artist_repo
        self.mock_win._ctx.toast = MagicMock()
        self.mock_win._ctx.rebuild_sidebar = MagicMock()
        self.mock_win._artist_grid = MagicMock()
        self.mock_win._artist_detail = MagicMock()
        self.mock_win._nav_ctrl = MagicMock()
        self.ctrl = ArtistController(self.mock_win)

    def test_create_artist_mix_with_tracks(self):
        items = [
            _make_item(filepath="/tmp/a.flac", play_count=10),
            _make_item(filepath="/tmp/b.flac", play_count=5),
            _make_item(filepath="/tmp/c.flac", play_count=1),
        ]
        self.mock_win._artist_repo.build(items)
        key = self.mock_win._artist_repo.groups[0].key

        self.mock_win._db = MagicMock()
        self.mock_win._db.create_playlist.return_value = 1
        self.mock_win._db.get_playlist_by_name.return_value = None
        self.mock_win._ctx.db = self.mock_win._db

        # Should not crash
        self.ctrl.create_artist_mix(key)
        assert self.mock_win._db.create_playlist.called

    def test_analyze_artist_discography_no_audio_lab(self):
        items = [_make_item()]
        self.mock_win._artist_repo.build(items)
        key = self.mock_win._artist_repo.groups[0].key

        self.mock_win._audio_analysis = None
        self.ctrl.analyze_artist_discography(key)
        # Should not crash — falls back to toast
        assert self.mock_win._ctx.toast.show.called

    def test_send_to_micro_server_without_server(self):
        items = [_make_item()]
        self.mock_win._artist_repo.build(items)
        key = self.mock_win._artist_repo.groups[0].key

        self.ctrl.send_artist_to_micro_server(key)
        assert self.mock_win._ctx.toast.show.called

    def test_resolve_aliases_no_duplicates(self):
        items = [_make_item()]
        self.mock_win._artist_repo.build(items)
        key = self.mock_win._artist_repo.groups[0].key

        self.ctrl.resolve_artist_aliases(key)
        assert self.mock_win._ctx.toast.show.called

    def test_analyze_artist_track(self):
        self.mock_win._audio_analysis = None
        self.ctrl.analyze_artist_track("/tmp/track.flac")
        assert self.mock_win._ctx.toast.show.called

    def test_analyze_artist_album(self):
        self.mock_win._audio_analysis = None
        self.ctrl.analyze_artist_album(["/tmp/a.flac", "/tmp/b.flac"])
        assert self.mock_win._ctx.toast.show.called
