"""Wheel verification tests for X10.27-28 packaging isolation."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)

from __future__ import annotations

import os
import subprocess
import sys
import zipfile
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
DIST = REPO / "dist"


def _build_wheel() -> str:
    subprocess.check_call(
        [sys.executable, "-m", "build", "--wheel", str(REPO)],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    wheels = sorted(DIST.glob("*.whl"))
    assert wheels, "No wheel found in dist/"
    return str(wheels[-1])


def _wheel_files(wheel_path: str) -> list[str]:
    names = []
    with zipfile.ZipFile(wheel_path) as z:
        for name in z.namelist():
            if not name.endswith("/"):
                names.append(name)
    return names


def test_wheel_builds():
    wheel = _build_wheel()
    assert wheel.endswith(".whl"), f"Not a wheel: {wheel}"
    assert os.path.getsize(wheel) > 1000, f"Wheel too small: {os.path.getsize(wheel)}"


def test_wheel_contains_no_ui_window():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    forbidden = [f for f in files if "ui/window.py" in f or "ui\\window.py" in f]
    assert not forbidden, f"Wheel must NOT contain ui/window.py: {forbidden}"


def test_wheel_contains_no_qwidget_pages():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    forbidden = [
        f for f in files
        if "ui/nowplaying_bar.py" in f
        or "ui/sidebar_widget.py" in f
        or "ui/view_controller.py" in f
    ]
    assert not forbidden, f"Wheel contains QWidget page files: {forbidden}"


def test_wheel_contains_no_legacy_widgets():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    lw = [f for f in files if "legacy_widgets" in f]
    assert not lw, f"Wheel must NOT contain legacy_widgets: {lw}"


def test_wheel_contains_core_modules():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    core_mods = [
        "core/service_container.py",
        "core/application_bootstrap.py",
        "audio/player_service.py",
        "library/library_db.py",
    ]
    missing = [m for m in core_mods if not any(m in f for f in files)]
    assert not missing, f"Core modules missing from wheel: {missing}"


def test_wheel_contains_qml_bridge():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    bridge_files = [
        "ui_qml_bridge/bridge_factory.py",
        "ui_qml_bridge/context_bindings.py",
    ]
    missing = [b for b in bridge_files if not any(b in f for f in files)]
    assert not missing, f"Bridge modules missing from wheel: {missing}"


def test_wheel_does_not_contain_tests():
    wheel = _build_wheel()
    files = _wheel_files(wheel)
    tests = [f for f in files if f.startswith("tests/") or f.startswith("tests\\")]
    assert not tests, f"Wheel must NOT contain test files: {tests}"
