"""Tests for ServerBrowserController."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
from unittest.mock import MagicMock, patch

import pytest


@pytest.fixture
def win():
    w = MagicMock()
    w._rebuild_sidebar = MagicMock()
    w._load_library = MagicMock()
    w._play_trackref = MagicMock()
    w._views = MagicMock()
    w._search_ctrl = MagicMock()
    w._search = MagicMock()
    w._section_title = MagicMock()
    w._count = MagicMock()
    w._current_section_key = "radio"
    w._radio_widget = MagicMock()
    w._fade_content = MagicMock()
    return w


@pytest.fixture
def ctrl(win):
    from legacy_widgets.ui.controllers.legacy_controllers.server_browser_controller import ServerBrowserController
    return ServerBrowserController(win)


class TestServerBrowserController:
    def test_add_server_dialog_accepted(self, ctrl, win):
        with (patch("ui.controllers.server_browser_controller.ServerDialog") as mock_dlg_cls,
              patch("ui.controllers.server_browser_controller.load_servers",
                    return_value=[]),
              patch("ui.controllers.server_browser_controller.save_servers") as mock_save):
            mock_dlg = mock_dlg_cls.return_value
            mock_dlg.exec.return_value = True
            mock_dlg.server = MagicMock()
            mock_dlg.server.name = "MyServer"
            ctrl.add_server()
            mock_save.assert_called_once()
            win._rebuild_sidebar.assert_called_once()

    def test_add_server_dialog_cancelled(self, ctrl, win):
        with (patch("ui.controllers.server_browser_controller.ServerDialog") as mock_dlg_cls,
              patch("ui.controllers.server_browser_controller.save_servers") as mock_save):
            mock_dlg = mock_dlg_cls.return_value
            mock_dlg.exec.return_value = False
            ctrl.add_server()
            mock_save.assert_not_called()

    def test_open_server_not_found(self, ctrl, win):
        with (patch("ui.controllers.server_browser_controller.load_servers",
                    return_value=[]),
              patch("ui.controllers.server_browser_controller.QMessageBox.warning") as mock_warn):
            ctrl.open_server("Nonexistent")
            mock_warn.assert_called_once()

    def test_open_server_success(self, ctrl, win):
        srv = MagicMock()
        srv.name = "TestServer"
        with (patch("ui.controllers.server_browser_controller.load_servers",
                    return_value=[srv]),
              patch("ui.controllers.server_browser_controller.SubsonicClient") as mock_cls,
              patch("ui.controllers.server_browser_controller.RemoteBrowser") as mock_rb_cls,
              patch("sources.subsonic_source.SubsonicSource"),
              patch("ui.controllers.server_browser_controller.QMessageBox")):
            mock_rb = mock_rb_cls.return_value
            mock_rb._workers = MagicMock()
            ctrl.open_server("TestServer")
            mock_cls.assert_called_with(srv)
            win._views.replace.assert_called_with("remote", mock_rb)
            win._views.show.assert_called_with("remote")
            win._section_title.setText.assert_called_with("TestServer")

    def test_open_server_auth_error(self, ctrl, win):
        srv = MagicMock()
        srv.name = "TestServer"
        exc_type = __import__(
            "streaming.subsonic_client", fromlist=["AuthError"]
        ).AuthError
        with (patch("ui.controllers.server_browser_controller.load_servers",
                    return_value=[srv]),
              patch("ui.controllers.server_browser_controller.SubsonicClient",
                    side_effect=exc_type("bad auth")),
              patch("ui.controllers.server_browser_controller.QMessageBox.warning") as mock_warn):
            ctrl.open_server("TestServer")
            mock_warn.assert_called()

    def test_remove_server_confirmed(self, ctrl, win):
        with (patch("ui.controllers.server_browser_controller.load_servers",
                    return_value=[MagicMock()]),
              patch("ui.controllers.server_browser_controller.save_servers") as mock_save,
              patch("ui.controllers.server_browser_controller.QMessageBox.question",
                    return_value=__import__("PySide6.QtWidgets").QtWidgets.QMessageBox.Yes)):
            ctrl.remove_server("SomeServer")
            mock_save.assert_called_once()
            win._rebuild_sidebar.assert_called_once()
            win._load_library.assert_called_once()

    def test_remove_server_declined(self, ctrl, win):
        with (patch("ui.controllers.server_browser_controller.load_servers"),
              patch("ui.controllers.server_browser_controller.save_servers") as mock_save,
              patch("ui.controllers.server_browser_controller.QMessageBox.question",
                    return_value=__import__("PySide6.QtWidgets").QtWidgets.QMessageBox.No)):
            ctrl.remove_server("SomeServer")
            mock_save.assert_not_called()

    def test_play_stream_creates_trackref(self, ctrl, win):
        ctrl.play_stream("http://stream", "Title", "Artist", "Album")
        win._play_trackref.assert_called_once()
        tr = win._play_trackref.call_args[0][0]
        assert tr.uri == "http://stream"
        assert tr.title == "Title"
        assert tr.artist == "Artist"
        assert tr.album == "Album"
        assert tr.source_type == "remote_stream"

    def test_play_radio_creates_trackref(self, ctrl, win):
        ctrl.play_radio("http://radio", "RadioName")
        win._play_trackref.assert_called_once()
        tr = win._play_trackref.call_args[0][0]
        assert tr.uri == "http://radio"
        assert tr.title == "RadioName"
        assert tr.artist == "Radio"
        assert tr.source_type == "radio"

    def test_on_radio_count_same_section(self, ctrl, win):
        win._current_section_key = "radio"
        ctrl.on_radio_count(5, 10)
        win._count.setText.assert_called_with("5 de 10 emisoras")

    def test_on_radio_count_all_visible(self, ctrl, win):
        win._current_section_key = "radio"
        ctrl.on_radio_count(10, 10)
        win._count.setText.assert_called_with("10 emisoras")

    def test_on_radio_count_different_section(self, ctrl, win):
        win._current_section_key = "library"
        ctrl.on_radio_count(5, 10)
        win._count.setText.assert_not_called()

    def test_show_radio_sets_section_and_fades(self, ctrl, win):
        ctrl.show_radio("radio")
        win._search_ctrl.set_active.assert_called_with("radio")
        assert win._current_section_key == "radio"
        win._radio_widget.reload.assert_called_once()
        win._fade_content.assert_called_with("radio")
