"""Tests for LibraryImporter — path building, sanitization, import, and DB integration."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
import os
import tempfile
from unittest.mock import MagicMock

import pytest

from legacy_widgets.ui.audio_lab.services.library_importer import (
    LibraryImporter,
    sanitize_filename,
)


class TestSanitize:
    def test_removes_unsafe_chars(self):
        assert sanitize_filename("AC/DC") == "AC_DC"
        assert sanitize_filename('file:name') == "file_name"

    def test_removes_path_traversal(self):
        result = sanitize_filename("../../../etc")
        assert "etc" in result
        assert ".." not in result

    def test_keeps_safe_name(self):
        assert sanitize_filename("The Beatles") == "The Beatles"

    def test_fallback_unknown(self):
        assert sanitize_filename("") == "unknown"
        assert sanitize_filename("...") == "_"


class TestLibraryImporter:
    @pytest.fixture
    def importer(self):
        tmpdir = tempfile.mkdtemp()
        imp = LibraryImporter(base_dir=tmpdir)
        yield imp
        import shutil
        shutil.rmtree(tmpdir, ignore_errors=True)

    # ── Path building ──

    def test_build_path_complete(self, importer):
        meta = {
            "artist": "Artist", "album": "Album",
            "title": "Title", "tracknumber": 3, "ext": "flac",
        }
        path = importer.build_destination_path(meta)
        assert "Artist" in path
        assert "Album" in path
        assert "03 - Title.flac" in path

    def test_build_path_uses_albumartist(self, importer):
        meta = {
            "albumartist": "DJ", "artist": "Various",
            "album": "Mix", "title": "Track", "ext": "mp3",
        }
        path = importer.build_destination_path(meta)
        assert "DJ" in path
        assert "Various" not in path

    def test_build_path_fallback_unknown(self, importer):
        meta = {}
        path = importer.build_destination_path(meta)
        assert "Unknown Artist" in path
        assert "Unknown Album" in path
        assert "Untitled.flac" in path

    def test_build_path_sanitizes_dangerous(self, importer):
        meta = {
            "artist": "AC/DC", "album": "Back:In Black",
            "title": "Hells Bells", "ext": "mp3",
        }
        path = importer.build_destination_path(meta)
        assert "/" not in os.path.basename(os.path.dirname(path))
        assert ":" not in path

    # ── Import ──

    def test_import_copies_file(self, importer):
        tmpdir = tempfile.mkdtemp()
        try:
            src = os.path.join(tmpdir, "track.flac")
            with open(src, "wb") as f:
                f.write(b"fLaC" + b"\x00" * 100)
            result = importer.import_tracks(
                [src],
                {"artist": "A", "album": "B", "title": "T", "ext": "flac"},
            )
            assert len(result["ok"]) == 1
            assert os.path.isfile(result["ok"][0])
        finally:
            import shutil
            shutil.rmtree(tmpdir, ignore_errors=True)

    def test_import_missing_source(self, importer):
        result = importer.import_tracks(["/nonexistent/file.mp3"], {})
        assert len(result["ok"]) == 0
        assert len(result["failed"]) == 1

    def test_import_partial_failure(self, importer):
        tmpdir = tempfile.mkdtemp()
        try:
            src = os.path.join(tmpdir, "good.flac")
            with open(src, "wb") as f:
                f.write(b"fLaC" + b"\x00" * 100)
            result = importer.import_tracks(
                [src, "/nonexistent/bad.mp3"],
                {"artist": "A", "album": "B", "title": "T", "ext": "flac"},
            )
            assert len(result["ok"]) == 1
            assert len(result["failed"]) == 1
        finally:
            import shutil
            shutil.rmtree(tmpdir, ignore_errors=True)

    def test_import_avoids_overwrite(self, importer):
        meta = {"artist": "A", "album": "B", "title": "T", "ext": "flac"}
        dest = importer.build_destination_path(meta)
        os.makedirs(os.path.dirname(dest), exist_ok=True)
        with open(dest, "w") as f:
            f.write("existing")

        tmpdir = tempfile.mkdtemp()
        try:
            src = os.path.join(tmpdir, "track.flac")
            with open(src, "wb") as f:
                f.write(b"fLaC" + b"\x00" * 100)
            result = importer.import_tracks([src], meta)
            imported = result["ok"][0]
            assert imported != dest  # different path due to counter
        finally:
            import shutil
            shutil.rmtree(tmpdir, ignore_errors=True)

    # ── Library integration ──

    def test_add_to_library_calls_db(self, importer):
        importer._db = MagicMock()
        importer._db.add_file.return_value = 1
        count = importer.add_to_library(["/tmp/a.mp3", "/tmp/b.mp3"])
        assert count == 2
        assert importer._db.add_file.call_count == 2

    def test_add_to_library_no_db(self, importer):
        count = importer.add_to_library(["/tmp/a.mp3"])
        assert count == 0

    def test_refresh_with_callback(self, importer):
        cb = MagicMock()
        result = importer.refresh_library_index(callback=cb)
        assert result["status"] == "ok"
        cb.assert_called_once()

    def test_refresh_without_callback(self, importer):
        result = importer.refresh_library_index()
        assert result["status"] == "pending"
