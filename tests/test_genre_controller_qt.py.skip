"""Tests: GenreController + real widget integration with qtbot."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
import pytest
from unittest.mock import MagicMock

from metadata.genre_grouping import GenreGroup


@pytest.fixture
def mock_window(qtbot):
    """Minimal mock window with real widgets for genre testing."""
    from unittest.mock import MagicMock
    w = MagicMock()
    w._nav_ctrl = MagicMock()
    w._nav_ctrl.checkpoint = MagicMock()
    w._playback_ctrl = None
    w._ctx = MagicMock()
    w._ctx.section_title = MagicMock()
    w._ctx.section_subtitle = MagicMock()
    w._ctx.view_switcher = MagicMock()
    w._ctx.fade_to = MagicMock()
    w._ctx.show_library_hub = MagicMock()
    w._ctx.set_library_tab = MagicMock()
    w._context_svc = MagicMock()
    return w


@pytest.fixture
def genre_group():
    g = GenreGroup(
        key="rock",
        name="Rock",
        canonical_name="Rock",
        family="Rock",
        track_count=50,
        artist_count=10,
        album_count=5,
        total_duration=18000.0,
        lossless_count=40,
        lossy_count=10,
        hi_res_count=5,
        cover_paths=[],
        quality_summary="Lossless",
    )
    g.tracks = []
    return g


class TestGenreControllerQt:
    @pytest.fixture
    def ctrl(self, mock_window):
        from legacy_widgets.ui.controllers.legacy_controllers.genre_controller import GenreController
        return GenreController(mock_window)

    def test_instantiation(self, ctrl):
        assert ctrl is not None

    def test_play_genre_calls_playback(self, ctrl):
        svc = MagicMock()
        ctrl._svc = svc
        ctrl._repo = MagicMock()
        ctrl._repo.filepaths_for_genre.return_value = ["/a.flac"]
        svc.playback = MagicMock()
        ctrl.play_genre("rock")
        svc.playback.play_queue.assert_called_once()

    def test_queue_genre_no_playback_ctrl(self, ctrl):
        svc = MagicMock()
        ctrl._svc = svc
        ctrl._repo = MagicMock()
        ctrl._repo.filepaths_for_genre.return_value = ["/a.flac"]
        svc.playback = MagicMock()
        ctrl._win._playback_ctrl = None
        ctrl.queue_genre("rock")
        svc.playback.enqueue.assert_called_once()

    def test_create_playlist_from_genre(self, ctrl, genre_group):
        svc = MagicMock()
        ctrl._svc = svc
        ctrl._stats_svc = MagicMock()
        ctrl._stats_svc.get_tracks_for_genre.return_value = []
        ctrl._repo = MagicMock()
        ctrl._repo.get_group.return_value = genre_group
        svc.db = MagicMock()
        svc.db.create_playlist.return_value = 1
        ctrl.create_playlist_from_genre("rock")
        assert svc.toast.show.called

    def test_show_genres_hub_fallback(self, ctrl):
        ctrl._stats_svc = None
        ctrl._hub_page = None
        with pytest.MonkeyPatch.context() as mp:
            mp.setattr(ctrl, 'show_genres_overview', MagicMock())
            ctrl.show_genres_hub()
            ctrl.show_genres_overview.assert_called_once()

    def test_normalize_genre_with_cleanup(self, ctrl):
        ctrl._cleanup_ctrl = MagicMock()
        ctrl._cleanup_ctrl.execute_rename.return_value = 5
        ctrl._show_toast = MagicMock()
        ctrl.normalize_genre("Rock")
        ctrl._cleanup_ctrl.execute_rename.assert_called_once()

    def test_create_mix_for_genre(self, ctrl):
        ctrl._mix_svc = MagicMock()
        ctrl._mix_svc.create_mix.return_value = []
        ctrl._show_toast = MagicMock()
        ctrl.create_mix_for_genre("Rock")
        ctrl._mix_svc.create_mix.assert_called_once_with("Rock", mode="all", limit=30)
