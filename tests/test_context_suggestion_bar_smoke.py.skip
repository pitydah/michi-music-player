"""Smoke test for ContextSuggestionBar widget."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)

from __future__ import annotations

from PySide6.QtWidgets import QVBoxLayout, QWidget

from legacy_widgets.ui.assistant.context_suggestion_bar import ContextSuggestionBar


def test_context_suggestion_bar_creation(qtbot):
    widget = ContextSuggestionBar()
    qtbot.add_widget(widget)
    assert widget.objectName() == "contextSuggestionBar"
    assert widget.isVisible() is False


def test_context_suggestion_bar_with_suggestions(qtbot):
    widget = ContextSuggestionBar()
    qtbot.add_widget(widget)
    suggestions = [
        {"id": "test_1", "title": "Test 1", "description": "Desc 1", "section": "test", "action": "test", "args": {}, "priority": "low", "requires_confirmation": False, "reason": ""},
        {"id": "test_2", "title": "Test 2", "description": "Desc 2", "section": "test", "action": "test", "args": {}, "priority": "medium", "requires_confirmation": False, "reason": ""},
        {"id": "test_3", "title": "Test 3", "description": "Desc 3", "section": "test", "action": "test", "args": {}, "priority": "high", "requires_confirmation": False, "reason": ""},
    ]
    widget.set_suggestions(suggestions)
    assert widget.isVisible() is True


def test_context_suggestion_bar_clear(qtbot):
    widget = ContextSuggestionBar()
    qtbot.add_widget(widget)
    suggestions = [{"id": "test_1", "title": "Test", "description": "Desc", "section": "test", "action": "test", "args": {}, "priority": "low", "requires_confirmation": False, "reason": ""}]
    widget.set_suggestions(suggestions)
    assert widget.isVisible() is True
    widget.clear()
    assert widget.isVisible() is False


def test_context_suggestion_bar_insert_in_layout(qtbot):
    parent = QWidget()
    layout = QVBoxLayout(parent)
    bar = ContextSuggestionBar()
    layout.insertWidget(0, bar)
    qtbot.add_widget(parent)
    assert bar.parent() is parent
    assert bar.isVisible() is False


def test_suggestion_card_creation(qtbot):
    from ui.assistant.suggestion_card import SuggestionCard
    card = SuggestionCard("test_card", "Card Title", "Card desc")
    qtbot.add_widget(card)
    assert card is not None
