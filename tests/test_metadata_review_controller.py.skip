"""Tests for MetadataReviewController."""
import pytest; pytest.skip("legacy_widgets removed", allow_module_level=True)
from unittest.mock import MagicMock, patch

import pytest


@pytest.fixture
def ctrl():
    from legacy_widgets.ui.controllers.legacy_controllers.metadata_review_controller import (
        MetadataReviewController,
    )
    c = MetadataReviewController.__new__(MetadataReviewController)
    from PySide6.QtCore import QObject
    QObject.__init__(c)
    c._db = MagicMock()
    c._kb = None
    c._service = None
    return c


class TestMetadataReviewController:
    def test_get_service_creates_lazily(self, ctrl):
        with patch(
            "metadata.review.metadata_review_service.MetadataReviewService"
        ) as mock_cls:
            svc = ctrl._get_service()
            mock_cls.assert_called_once_with(ctrl._db, ctrl._kb)
            assert ctrl._service is svc

    def test_get_service_returns_cached(self, ctrl):
        svc = MagicMock()
        ctrl._service = svc
        assert ctrl._get_service() is svc

    def test_load_review(self, ctrl):
        svc = MagicMock()
        svc.load_review.return_value = {"id": "r1"}
        ctrl._service = svc
        result = ctrl.load_review("r1")
        svc.load_review.assert_called_with("r1")
        assert result == {"id": "r1"}

    def test_create_review(self, ctrl):
        svc = MagicMock()
        svc.create_review.return_value = {"id": "r1"}
        ctrl._service = svc
        result = ctrl.create_review([1, 2, 3])
        svc.create_review.assert_called_with([1, 2, 3])
        assert result == {"id": "r1"}

    def test_apply_review_emits_apply_result(self, ctrl):
        svc = MagicMock()
        svc.apply_review.return_value = {"status": "applied"}
        ctrl._service = svc
        results = []
        ctrl.apply_result.connect(lambda r: results.append(r))
        result = ctrl.apply_review("r1", {1: ["title"]})
        svc.apply_review.assert_called_with("r1", {1: ["title"]})
        assert result == {"status": "applied"}
        assert results == [{"status": "applied"}]

    def test_reject_review(self, ctrl):
        svc = MagicMock()
        svc.reject_review.return_value = {"status": "rejected"}
        ctrl._service = svc
        result = ctrl.reject_review("r1")
        svc.reject_review.assert_called_with("r1")
        assert result == {"status": "rejected"}

    def test_undo_review(self, ctrl):
        svc = MagicMock()
        svc.undo_review.return_value = {"status": "undone"}
        ctrl._service = svc
        result = ctrl.undo_review("r1")
        svc.undo_review.assert_called_with("r1")
        assert result == {"status": "undone"}
