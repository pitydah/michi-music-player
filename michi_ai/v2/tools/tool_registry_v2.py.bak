from __future__ import annotations

import inspect
import logging
import time
from typing import Any, Callable

from michi_ai.v2.core.cancellation import CancellationToken
from michi_ai.v2.core.models import (
    ErrorCode, ToolDefinition, ToolExecutionResult,
)
from michi_ai.v2.intent.capability_resolver import CapabilityResolver

logger = logging.getLogger(__name__)


class ToolRegistryV2:
    def __init__(self, capability_resolver: CapabilityResolver | None = None) -> None:
        self._tools: dict[str, ToolDefinition] = {}
        self._handlers: dict[str, Callable[..., dict[str, Any]]] = {}
        self._capability_resolver = capability_resolver or CapabilityResolver()

    def register(self, defn: ToolDefinition) -> None:
        if defn.name in self._tools:
            logger.warning("Tool '%s' already registered, overwriting", defn.name)
        self._tools[defn.name] = defn
        self._handlers[defn.name] = defn.handler
        for cap_name in defn.capabilities:
            self._capability_resolver.register(
                cap_name, available=defn.handler is not None,
                permission=defn.permission,
                requires_confirmation=defn.requires_confirmation,
            )

    def register_handler(self, name: str, handler: Callable[..., dict[str, Any]]) -> None:
        if name in self._tools:
            self._tools[name] = self._tools[name].with_handler(handler)
            self._handlers[name] = handler
        else:
            logger.warning("Cannot register handler for unknown tool '%s'", name)

    def get(self, name: str) -> ToolDefinition | None:
        return self._tools.get(name)

    def get_handler(self, name: str) -> Callable[..., dict[str, Any]] | None:
        return self._handlers.get(name)

    def list_tools(self) -> list[ToolDefinition]:
        return list(self._tools.values())

    def has_tool(self, name: str) -> bool:
        return name in self._tools

    def execute(
        self,
        name: str,
        arguments: dict[str, Any] | None = None,
        cancellation_token: CancellationToken | None = None,
        correlation_id: str = "",
    ) -> ToolExecutionResult:
        args = arguments or {}
        defn = self._tools.get(name)
        if defn is None:
            return ToolExecutionResult(
                ok=False, tool_name=name, error=f"Tool '{name}' not found",
                code=ErrorCode.TOOL_NOT_FOUND, correlation_id=correlation_id,
            )

        capabilities = self._capability_resolver.resolve(list(defn.capabilities))
        unavailable = [k for k, v in capabilities.items() if not v.available]
        if unavailable:
            return ToolExecutionResult(
                ok=False, tool_name=name,
                error=f"Required capabilities unavailable: {', '.join(unavailable)}",
                code=ErrorCode.CAPABILITY_UNAVAILABLE, correlation_id=correlation_id,
            )

        validation_error = self._validate_args(defn, args)
        if validation_error:
            return ToolExecutionResult(
                ok=False, tool_name=name, error=validation_error,
                code=ErrorCode.INVALID_ARGUMENTS, correlation_id=correlation_id,
            )

        handler = self._handlers.get(name)
        if handler is None:
            return ToolExecutionResult(
                ok=False, tool_name=name, error=f"No handler for tool '{name}'",
                code=ErrorCode.TOOL_UNAVAILABLE, correlation_id=correlation_id,
            )

        filtered_args = self._filter_args(handler, args)
        start = time.monotonic()
        try:
            if cancellation_token:
                cancellation_token.check()
            result = handler(**filtered_args)
            duration = (time.monotonic() - start) * 1000
            if not isinstance(result, dict):
                return ToolExecutionResult(
                    ok=False, tool_name=name, error="Handler returned non-dict result",
                    code=ErrorCode.TOOL_FAILED, duration_ms=duration,
                    correlation_id=correlation_id,
                )
            is_ok = result.get("ok", result.get("success", True))
            return ToolExecutionResult(
                ok=bool(is_ok), tool_name=name, data=result,
                error=result.get("error", ""),
                code=ErrorCode.OK if is_ok else ErrorCode.TOOL_FAILED,
                duration_ms=duration, correlation_id=correlation_id,
            )
        except Exception as e:
            duration = (time.monotonic() - start) * 1000
            return ToolExecutionResult(
                ok=False, tool_name=name, error=str(e),
                code=ErrorCode.TOOL_FAILED, duration_ms=duration,
                correlation_id=correlation_id,
            )

    def _validate_args(self, defn: ToolDefinition, args: dict[str, Any]) -> str:
        schema = defn.input_schema
        if not schema:
            return ""
        required = schema.get("required", [])
        properties = schema.get("properties", {})

        for field in required:
            if field not in args:
                return f"Missing required argument: '{field}'"

        allowed = set(properties.keys()) | set(required)
        unknown = set(args.keys()) - allowed
        if unknown and schema.get("additionalProperties", True) is False:
            return f"Unknown arguments: {', '.join(unknown)}"

        for field, value in args.items():
            prop = properties.get(field)
            if prop is None:
                continue
            expected_type = prop.get("type")
            if expected_type and value is not None:
                type_map = {
                    "string": str, "integer": int, "number": (int, float),
                    "boolean": bool, "array": list, "object": dict,
                }
                py_type = type_map.get(expected_type)
                if py_type and not isinstance(value, py_type):
                    return f"Argument '{field}' expected {expected_type}, got {type(value).__name__}"
        return ""

    def _filter_args(self, handler: Callable, args: dict[str, Any]) -> dict[str, Any]:
        try:
            sig = inspect.signature(handler)
            param_names = set(sig.parameters.keys())
            return {k: v for k, v in args.items() if k in param_names}
        except (ValueError, TypeError):
            return dict(args)

    @property
    def capability_resolver(self) -> CapabilityResolver:
        return self._capability_resolver
